{
  "$schema": "https://openclaw.dev/schemas/plugin.v1.json",
  "name": "sendsprint",
  "version": "0.3.0",
  "description": "SendSprint integration for OpenClaw. OpenClaw runs as an independent review + security validator around SendSprint deliveries — never bypasses policy gates.",
  "author": {
    "name": "Wesley Simplicio",
    "email": "wesleybob4@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/wesleysimplicio/sendsprint",
  "runtime": {
    "type": "python-cli",
    "entrypoint": "sendsprint",
    "min_version": "0.22.0",
    "install": "pip install sendsprint && playwright install chromium"
  },
  "role": "reviewer",
  "stance": "read-only-by-default",
  "skills": [
    { "path": "./skills/sendsprint.md", "name": "sendsprint" }
  ],
  "commands": [
    { "name": "review-sprint", "path": "./commands/review-sprint.md" },
    { "name": "preflight", "path": "./commands/preflight.md", "exec": "sendsprint preflight" },
    { "name": "security-review", "path": "./commands/security-review.md" },
    { "name": "doctor", "path": "./commands/doctor.md", "exec": "sendsprint doctor" },
    { "name": "inspect-run", "path": "./commands/inspect-run.md", "exec": "sendsprint sprint inspect" }
  ],
  "hooks": {
    "pre_commit": "./hooks/pre-commit.sh",
    "post_edit": "./hooks/post-edit.sh"
  },
  "triggers": {
    "phrases": {
      "pt-BR": ["revisar sprint", "auditar entrega", "validar sendsprint"],
      "en": ["review sprint", "audit delivery", "validate sendsprint", "security review sprint"],
      "es": ["revisar sprint", "auditar entrega"]
    },
    "slash": ["/review-sprint", "/preflight", "/security-review", "/inspect-run"]
  },
  "policy": {
    "security": "flag-only",
    "auto_fix_security": false,
    "may_open_prs": false,
    "may_push_commits": false,
    "must_inspect_artifacts": ["report.json", "evidence/", ".sendsprint/"]
  }
}
