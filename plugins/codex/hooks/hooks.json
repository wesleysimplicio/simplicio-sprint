{
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        { "type": "command", "command": "bash \"${CODEX_PLUGIN_ROOT:-./plugins/codex}/hooks/pre-commit.sh\"" }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        { "type": "command", "command": "bash \"${CODEX_PLUGIN_ROOT:-./plugins/codex}/hooks/post-edit.sh\"" }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": "*",
      "hooks": [
        { "type": "command", "command": "bash \"${CODEX_PLUGIN_ROOT:-./plugins/codex}/hooks/session-start.sh\"" }
      ]
    }
  ]
}
