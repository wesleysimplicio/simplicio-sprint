# SendSprint environment variables — copy to .env and fill in. Never commit .env.

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Azure DevOps
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# GitHub (issues as source + PR creation)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# simplicio-cli (the executor) — read by simplicio itself
SIMPLICIO_MODEL=
SIMPLICIO_BASE_URL=
SIMPLICIO_TEST_CMD=pytest -q

# LLM (optional, for task organization)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
