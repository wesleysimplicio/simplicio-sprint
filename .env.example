# ------------------------------------------------------------------
# SendSprint - copy to .env and fill in. Never commit .env.
# ------------------------------------------------------------------

# --- Jira ----------------------------------------------------------
# Used by JiraOperator when transport=api
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=__redacted__

# --- Azure DevOps --------------------------------------------------
# Used by AzureDevopsOperator when transport=api
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=YourProject
AZURE_DEVOPS_PAT=__redacted__

# --- Playwright fallback ------------------------------------------
# When transport=playwright, SendSprint connects to an already-open
# Chromium via CDP. Start your browser with:
#   chromium --remote-debugging-port=9222
PLAYWRIGHT_CDP_URL=http://127.0.0.1:9222

# --- LLM provider --------------------------------------------------
# Pick ONE - leave the others blank.
LLM_PROVIDER=anthropic   # anthropic | openai | google | groq | ollama
LLM_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

# --- MCP (optional) -----------------------------------------------
# If you have an MCP server connected for Atlassian / Azure DevOps,
# SendSprint will auto-detect it via the host agent. No extra config.

# --- SendSprint ----------------------------------------------------
SENDSPRINT_OUTPUT_DIR=./.sendsprint
SENDSPRINT_LOG_LEVEL=INFO

# --- v2 dispatcher (providers.yml) --------------------------------
# Required by sendsprint.providers when the matching adapter is enabled.
# See providers.yml.example for the full config schema.
#
# Cloud + GitHub Actions adapters
# --------------------------------
# ANTHROPIC_API_KEY     reuses the LLM section above (Claude adapter)
# OPENAI_API_KEY        reuses the LLM section above (Codex adapter)
# CLAUDE_ROUTINE_ENV_ID identifies the Anthropic managed-agent environment
CLAUDE_ROUTINE_ENV_ID=
# CODEX_ENVIRONMENT_ID  identifies the Codex Cloud environment / microVM
CODEX_ENVIRONMENT_ID=
# GITHUB_TOKEN          PAT with repo scope; lets the Copilot adapter assign
#                       issues to @copilot. Never commit.
GITHUB_TOKEN=
# COPILOT_TARGET_REPO   owner/repo where Copilot opens the PR
COPILOT_TARGET_REPO=
#
# Local adapters (air-gapped / non-GitHub projects)
# -------------------------------------------------
# SENDSPRINT_LOCAL_REPO        repo root used to create per-task worktrees
#                              (defaults to ".")
SENDSPRINT_LOCAL_REPO=.
# RALPH_BINARY                 path to the ralph CLI (defaults to `ralph`)
RALPH_BINARY=ralph
# SENDSPRINT_LOCAL_AGENT_BINARY agent CLI used by local-goal (defaults to `claude`)
SENDSPRINT_LOCAL_AGENT_BINARY=claude
