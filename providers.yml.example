# SendSprint v2 dispatcher — copy to providers.yml and tune.
#
# The router treats every dispatchable adapter the same — cloud, local, or
# GitHub Actions. List only the modes your project can actually use:
#   * cloud-friendly  -> claude / codex / copilot (and optional spikes)
#   * GitHub-free     -> claude / codex + local-ralph / local-goal
#   * air-gapped      -> local-ralph / local-goal ONLY
#
# Spec: .specs/v2/cloud-dispatcher.md (INFRA + ROUTER sub-issues).

max_parallel: 3        # how many dispatches run concurrently
poll_interval_s: 10    # seconds between poll() calls per ticket
timeout_s: 1800        # wall-clock budget per ticket (30 min)

providers:
  # --- Cloud (mode=cloud) ---
  - name: claude       # needs ANTHROPIC_API_KEY
  - name: codex        # needs OPENAI_API_KEY + CODEX_ENVIRONMENT_ID

  # --- GitHub Actions (mode=github-action) ---
  - name: copilot      # needs GITHUB_TOKEN + COPILOT_TARGET_REPO

  # --- Local worktree loops (mode=local) — for air-gapped or non-GitHub repos ---
  - name: local-ralph  # needs `ralph` CLI + .ralph/config.toml in the repo
  - name: local-goal   # needs a local agent CLI (default: `claude`)

  # --- Spike adapters (dispatchable=false; router falls back) ---
  - name: cursor       # falls back to claude
  - name: windsurf     # falls back to claude
  - name: kiro         # falls back to codex
